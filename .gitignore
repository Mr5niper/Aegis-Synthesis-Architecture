# ===========================================================================
#  .gitignore  (Aegis-Synthesis-Architecture)
# ---------------------------------------------------------------------------

# --- Python caches ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --- Virtual environments (created by BUILD_EXE.bat / makefile) ------------
env/
venv/
.venv/

# --- PyInstaller build artifacts -------------------------------------------
# Regenerated by every build; never commit. NOTE: assistant_gui.spec is the
# project's checked-in build recipe and is intentionally NOT ignored below.
build/
dist/
*.exe

# --- Runtime data (DBs, keys, training data, exports) ----------------------
# Ignore the CONTENTS but keep the folders so the build + first run can write
# into them on a fresh clone. Add a tracked .gitkeep in each.
data/*
!data/.gitkeep
models/*
!models/.gitkeep

# --- Model weights (in case any land outside models/) ----------------------
*.gguf
*.bin
*.safetensors

# --- Logs ------------------------------------------------------------------
*.log

# --- IDE / editor ----------------------------------------------------------
.idea/
.vscode/

# --- OS cruft --------------------------------------------------------------
.DS_Store
Thumbs.db
